generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id                String         @id @default(cuid())
  name              String
  settlementPeriod  String         @default("none")
  createdAt         DateTime       @default(now())
  tenants           Tenant[]
  categories        Category[]
  expenses          Expense[]
  defaultSplits      DefaultSplit[]
  settlements        Settlement[]
  recurringExpenses  RecurringExpense[]
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  householdId   String
  createdAt     DateTime       @default(now())
  household        Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expensesPaid     Expense[]    @relation("PaidBy")
  expenseSplits    ExpenseSplit[]
  defaultSplits    DefaultSplit[]
  settlementsFrom       Settlement[]            @relation("SettlementFrom")
  settlementsTo         Settlement[]            @relation("SettlementTo")
  recurringExpensesPaid RecurringExpense[]      @relation("RecurringPaidBy")
  recurringExpenseSplits RecurringExpenseSplit[]

  @@index([householdId])
}

model Settlement {
  id           String    @id @default(cuid())
  householdId  String
  fromTenantId String
  toTenantId   String
  amount       Decimal   @db.Decimal(12, 2)
  note         String?
  date         DateTime  @default(now())
  createdAt    DateTime  @default(now())
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  fromTenant   Tenant    @relation("SettlementFrom", fields: [fromTenantId], references: [id], onDelete: Restrict)
  toTenant     Tenant    @relation("SettlementTo", fields: [toTenantId], references: [id], onDelete: Restrict)

  @@index([householdId])
}

model Category {
  id          String    @id @default(cuid())
  name        String
  householdId String
  household     Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  expenses      Expense[]
  defaultSplits DefaultSplit[]

  @@index([householdId])
}

model Expense {
  id                 String            @id @default(cuid())
  amount             Decimal           @db.Decimal(12, 2)
  description        String
  categoryId         String
  paidByTenantId     String
  householdId        String
  recurringExpenseId String?
  splitMode          String            @default("default")
  date               DateTime
  createdAt          DateTime          @default(now())
  category           Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  paidByTenant       Tenant            @relation("PaidBy", fields: [paidByTenantId], references: [id], onDelete: Restrict)
  household          Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  splits             ExpenseSplit[]

  @@index([householdId])
  @@index([recurringExpenseId])
}

model ExpenseSplit {
  id         String   @id @default(cuid())
  expenseId  String
  tenantId   String
  amount     Decimal  @db.Decimal(12, 2)
  percentage Float?
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id          String                  @id @default(cuid())
  householdId String
  title       String
  amount      Decimal                 @db.Decimal(12, 2)
  category    String?
  paidById    String
  frequency   String
  startDate   DateTime
  nextDueDate DateTime
  active      Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  household   Household               @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paidBy             Tenant                  @relation("RecurringPaidBy", fields: [paidById], references: [id], onDelete: Restrict)
  splits             RecurringExpenseSplit[]
  generatedExpenses  Expense[]

  @@index([householdId])
}

model RecurringExpenseSplit {
  id                 String           @id @default(cuid())
  recurringExpenseId String
  tenantId           String
  percentage         Float
  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model DefaultSplit {
  id          String    @id @default(cuid())
  householdId String
  categoryId  String?
  tenantId    String
  percentage  Float
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([householdId, categoryId, tenantId])
  @@index([householdId])
}
